# ZachAI — Environment Variables
# ================================
# Copy this file to .env before running 'docker compose up'.
# NEVER commit .env to git — it is already in .gitignore.
#
# ⚠️ SECURITY WARNING:
# Change ALL default credentials (minioadmin, changeme, etc.) before 
# deploying to any shared, public, or production environment.
# Using default credentials in production IS A CRITICAL SECURITY RISK.

# ─── MinIO (Object Storage) — Story 1.1 ──────────────────────────────────────
# Root credentials for the MinIO S3-compatible storage layer.
# Used by: minio service, minio-init service (bucket creation),
#          FastAPI (presigned URL generation — Story 1.3),
#          FFmpeg Worker (Story 3.1), OpenVINO (Story 3.2).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── PostgreSQL — Story 1.2 ──────────────────────────────────────────────────
# Single PostgreSQL 16 instance shared by Keycloak, ZachAI business model, and Camunda 7.
# Each service uses a dedicated database (keycloak / zachai / camunda).
# POSTGRES_USER is the superuser with access to all databases.
#
# ⚠️ SECURITY WARNING: Change POSTGRES_PASSWORD before deploying to any shared environment.
POSTGRES_USER=zachai
POSTGRES_PASSWORD=changeme
POSTGRES_DB=keycloak    # primary DB name (auto-created by PostgreSQL init)

# ─── Keycloak (IAM) — Story 1.2 ──────────────────────────────────────────────
# Keycloak 26.x admin bootstrap credentials.
# These are used ONCE to create the initial master realm admin.
# If the admin already exists (postgres_data volume persists), these are ignored.
# Admin console: http://localhost:8180/admin
#
# NOTE: KC_BOOTSTRAP_ADMIN_* is the Keycloak 26.x name — do NOT use deprecated KEYCLOAK_ADMIN_*.
#
# ⚠️ SECURITY WARNING: Change KC_BOOTSTRAP_ADMIN_PASSWORD before deploying to any shared environment.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=changeme

# ─── FFmpeg Worker (Story 3.1) ───────────────────────────────────────────────
# Internal-only service (port 8765, not exposed on host).
# Reuses MinIO root credentials for now — scoped service accounts deferred.
#
# ⚠️ SECURITY WARNING: Replace with scoped MinIO service account credentials
# before deploying to any shared or production environment.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ─── FastAPI Gateway — Story 1.3 ────────────────────────────────────────────
# Keycloak issuer URL as seen FROM INSIDE the Docker network (keycloak:8080, not localhost:8180).
# FastAPI fetches JWKS from this URL at startup to verify JWTs.
#
# MINIO_ENDPOINT, MINIO_ACCESS_KEY, MINIO_SECRET_KEY, MINIO_SECURE
# are already defined above (FFmpeg Worker section) — FastAPI reuses them.
#
# MINIO_PRESIGNED_ENDPOINT: the externally reachable MinIO URL used for presigned URL generation.
# Must use an address the BROWSER can resolve — not the internal Docker hostname 'minio:9000'.
# For local dev, this is 'localhost:9000'. For production, replace with your domain.
#
# ⚠️ SECURITY WARNING: Replace MINIO_ACCESS_KEY/SECRET_KEY with scoped MinIO service account
# credentials before deploying to any shared or production environment.
KEYCLOAK_ISSUER=http://keycloak:8080/realms/zachai
MINIO_PRESIGNED_ENDPOINT=localhost:9000

# ─── Redis — TODO: Story 5.2 ─────────────────────────────────────────────────
# REDIS_PASSWORD=changeme

# ─── Camunda 7 — TODO: Story 2.2 ─────────────────────────────────────────────
# CAMUNDA_URL=http://camunda7:8080/engine-rest
