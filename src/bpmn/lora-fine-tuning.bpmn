<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   id="Definitions_lora"
                   targetNamespace="http://zachai/lora-fine-tuning"
                   exporter="ZachAI" exporterVersion="2.2.0">

  <bpmn:process id="lora-fine-tuning" name="LoRA Fine-tuning" isExecutable="true" camunda:historyTimeToLive="P30D">

    <bpmn:startEvent id="StartEvent_LoRA" name="Threshold reached">
      <bpmn:outgoing>Flow_DS_0</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sequenceFlow id="Flow_DS_0" sourceRef="StartEvent_LoRA" targetRef="DatasetPrep"/>

    <bpmn:serviceTask id="DatasetPrep" name="Dataset preparation"
                      camunda:type="external" camunda:topic="lora-dataset-prep">
      <bpmn:incoming>Flow_DS_0</bpmn:incoming>
      <bpmn:outgoing>Flow_DS_1</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_DS_1" sourceRef="DatasetPrep" targetRef="RunLoRATraining"/>

    <bpmn:serviceTask id="RunLoRATraining" name="Run LoRA training"
                      camunda:type="external" camunda:topic="lora-training">
      <bpmn:incoming>Flow_DS_1</bpmn:incoming>
      <bpmn:outgoing>Flow_TR_1</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_TR_1" sourceRef="RunLoRATraining" targetRef="RunWEREval"/>

    <bpmn:serviceTask id="RunWEREval" name="WER evaluation"
                      camunda:type="external" camunda:topic="lora-wer-eval">
      <bpmn:incoming>Flow_TR_1</bpmn:incoming>
      <bpmn:outgoing>Flow_WE_1</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_WE_1" sourceRef="RunWEREval" targetRef="Gateway_WER"/>

    <bpmn:exclusiveGateway id="Gateway_WER" name="WER acceptable?" default="Flow_Reject">
      <bpmn:incoming>Flow_WE_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Accept</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_Accept" sourceRef="Gateway_WER" targetRef="PublishRegistry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${werAccepted == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Reject" sourceRef="Gateway_WER" targetRef="EndRejected"/>

    <bpmn:serviceTask id="PublishRegistry" name="Publish to model registry"
                      camunda:type="external" camunda:topic="lora-registry-publish">
      <bpmn:incoming>Flow_Accept</bpmn:incoming>
      <bpmn:outgoing>Flow_OK_1</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_OK_1" sourceRef="PublishRegistry" targetRef="EndAccepted"/>

    <bpmn:endEvent id="EndAccepted" name="Model deployed">
      <bpmn:incoming>Flow_OK_1</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejected" name="WER rejected">
      <bpmn:incoming>Flow_Reject</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_LoRA">
    <bpmndi:BPMNPlane id="BPMNPlane_LoRA" bpmnElement="lora-fine-tuning">
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_LoRA" bpmnElement="StartEvent_LoRA">
        <dc:Bounds x="152" y="232" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_DatasetPrep" bpmnElement="DatasetPrep">
        <dc:Bounds x="240" y="210" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RunLoRATraining" bpmnElement="RunLoRATraining">
        <dc:Bounds x="390" y="210" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RunWEREval" bpmnElement="RunWEREval">
        <dc:Bounds x="540" y="210" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_WER" bpmnElement="Gateway_WER" isMarkerVisible="true">
        <dc:Bounds x="695" y="225" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_PublishRegistry" bpmnElement="PublishRegistry">
        <dc:Bounds x="800" y="120" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndAccepted" bpmnElement="EndAccepted">
        <dc:Bounds x="962" y="142" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndRejected" bpmnElement="EndRejected">
        <dc:Bounds x="800" y="282" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_DS_0" bpmnElement="Flow_DS_0">
        <di:waypoint x="188" y="250"/>
        <di:waypoint x="240" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_DS_1" bpmnElement="Flow_DS_1">
        <di:waypoint x="340" y="250"/>
        <di:waypoint x="390" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_TR_1" bpmnElement="Flow_TR_1">
        <di:waypoint x="490" y="250"/>
        <di:waypoint x="540" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_WE_1" bpmnElement="Flow_WE_1">
        <di:waypoint x="640" y="250"/>
        <di:waypoint x="695" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_Accept" bpmnElement="Flow_Accept">
        <di:waypoint x="720" y="225"/>
        <di:waypoint x="720" y="160"/>
        <di:waypoint x="800" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_Reject" bpmnElement="Flow_Reject">
        <di:waypoint x="720" y="275"/>
        <di:waypoint x="720" y="300"/>
        <di:waypoint x="818" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_OK_1" bpmnElement="Flow_OK_1">
        <di:waypoint x="900" y="160"/>
        <di:waypoint x="962" y="160"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
